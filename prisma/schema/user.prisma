model User {
  id        String      @id @default(cuid()) @db.VarChar(50)
  name      String      @db.VarChar(100)
  password  String      @default("") @db.VarChar(255)
  email     String      @unique()
  createdAt DateTime    @default(now()) @map("created_at")
  classes   UserClass[]
  posts     Post[]
  profile   Profile?

  @@map("users")
}
