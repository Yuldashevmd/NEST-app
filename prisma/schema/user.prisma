model User {
  id        Int         @id @default(autoincrement())
  name      String      @db.VarChar(100)
  password  String      @db.VarChar(255) @default("")
  email     String      @unique()
  createdAt DateTime    @default(now()) @map("created_at")
  classes   UserClass[]
  posts     Post[]
  profile   Profile?

  @@map("users")
}
